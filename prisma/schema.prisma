generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// NextAuth / Auth.js (SSO reserved schema) & RBAC
// -----------------------------------------------------------------------------

enum Role {
  ADMIN
  SECOPS
  REPORTER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash       String?   // Added for Credentials provider MVP
  role               Role      @default(REPORTER)
  isTwoFactorEnabled Boolean   @default(false)
  twoFactorSecret    String?

  accounts           Account[]
  sessions           Session[]
  
  // Relations for OpenTicket
  reportedIncidents Incident[] @relation("Reporter")
  assignedIncidents Incident[] @relation("IncidentAssignees")
  comments          Comment[]
  auditLogs         AuditLog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -----------------------------------------------------------------------------
// Global Configuration (Singleton Model)
// -----------------------------------------------------------------------------

model SystemSetting {
  id                 String   @id @default("global") // Enforce singleton
  allowRegistration  Boolean  @default(true)
  requireGlobal2FA   Boolean  @default(false)
  defaultUserRole    Role     @default(REPORTER)

  updatedAt          DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// OpenTicket Core Models
// -----------------------------------------------------------------------------

enum AssetType {
  SERVER
  ENDPOINT
  NETWORK
  SOFTWARE
  OTHER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  COMPROMISED
  MAINTENANCE
}

model Asset {
  id        String      @id @default(cuid())
  name      String
  type      AssetType   @default(OTHER)
  ipAddress String?
  status    AssetStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  incidents       Incident[]
  vulnerabilities Vulnerability[] @relation("AssetVulnerabilities")
}

enum VulnStatus {
  OPEN
  MITIGATED
  RESOLVED
}

model Vulnerability {
  id          String     @id @default(cuid())
  title       String
  cveId       String?
  cvssScore   Float?
  description String     @db.Text
  severity    Severity   @default(LOW)
  status      VulnStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  affectedAssets Asset[] @relation("AssetVulnerabilities")
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  NEW
  IN_PROGRESS
  PENDING_INFO
  RESOLVED
  CLOSED
}

enum IncidentType {
  MALWARE
  PHISHING
  DATA_BREACH
  UNAUTHORIZED_ACCESS
  NETWORK_ANOMALY
  OTHER
}

model Incident {
  id          String         @id @default(cuid())
  title       String
  description String         @db.Text
  type        IncidentType   @default(OTHER)
  severity    Severity       @default(LOW)
  status      IncidentStatus @default(NEW)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  reporterId  String
  reporter    User     @relation("Reporter", fields: [reporterId], references: [id])
  
  assignees   User[]   @relation("IncidentAssignees")

  assetId     String?
  asset       Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)

  comments    Comment[]
}

model Comment {
  id         String   @id @default(cuid())
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String   // e.g., "INCIDENT_CREATED", "STATUS_CHANGED"
  entityType   String   // e.g., "Incident", "Asset"
  entityId     String
  changes      Json?    // Optional JSON payload detailing what changed
  createdAt    DateTime @default(now())
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: SetNull)
}
