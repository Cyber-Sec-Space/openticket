generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// NextAuth / Auth.js (SSO reserved schema) & RBAC
// -----------------------------------------------------------------------------

enum Role {
  ADMIN
  SECOPS
  REPORTER
  API_ACCESS
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String?   @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String? // Added for Credentials provider MVP
  roles              Role[]    @default([REPORTER])
  isTwoFactorEnabled Boolean   @default(false)
  twoFactorSecret    String?
  isDisabled         Boolean   @default(false) // Phase 5 Suspension Support

  // Browser Notification Preferences
  browserNotificationsEnabled Boolean @default(false)
  notifyOnCritical            Boolean @default(true)
  notifyOnHigh                Boolean @default(false)
  notifyOnAssign              Boolean @default(true)
  notifyOnResolution          Boolean @default(true)
  notifyOnAssetCompromise     Boolean @default(true)
  notifyOnUnassigned          Boolean @default(false)

  accounts  Account[]
  sessions  Session[]
  apiTokens ApiToken[]

  // Relations for OpenTicket
  reportedIncidents Incident[]   @relation("Reporter")
  assignedIncidents Incident[]   @relation("IncidentAssignees")
  comments          Comment[]
  auditLogs         AuditLog[]
  attachments       Attachment[]
  notifications     UserNotification[]
}

model UserNotification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  body        String
  link        String?
  isRead      Boolean  @default(false)
  isPushed    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

// -----------------------------------------------------------------------------
// Global Configuration (Singleton Model)
// -----------------------------------------------------------------------------

model SystemSetting {
  id                String  @id @default("global") // Enforce singleton
  allowRegistration Boolean @default(true)
  requireGlobal2FA  Boolean @default(false)
  defaultUserRoles  Role[]  @default([REPORTER])

  webhookUrl     String?
  webhookEnabled Boolean @default(false)

  // Global SLA Matrix Config (Hours)
  slaCriticalHours Int @default(4)
  slaHighHours     Int @default(24)
  slaMediumHours   Int @default(72)
  slaLowHours      Int @default(168)

  // Rate Limiting Config
  rateLimitEnabled     Boolean @default(true)
  rateLimitWindowMs    Int     @default(900000) // 15 minutes default
  rateLimitMaxAttempts Int     @default(5)

  // SMTP Configuration
  smtpEnabled          Boolean @default(false)
  smtpHost             String?
  smtpPort             Int?
  smtpUser             String?
  smtpPassword         String?
  smtpFrom             String?

  // SMTP Event Triggers
  smtpTriggerOnCritical         Boolean @default(true)
  smtpTriggerOnHigh             Boolean @default(false)
  smtpTriggerOnAssign           Boolean @default(true)
  smtpTriggerOnResolution       Boolean @default(true)
  smtpTriggerOnAssetCompromise  Boolean @default(true)
  smtpTriggerOnNewUser          Boolean @default(false)
  smtpTriggerOnNewVulnerability Boolean @default(true)

  // Auth Enforcements
  requireEmailVerification      Boolean @default(false)
  systemPlatformUrl             String  @default("http://localhost:3000")

  updatedAt DateTime @updatedAt
}

model LoginAttempt {
  id         String   @id @default(cuid())
  ip         String
  identifier String
  createdAt  DateTime @default(now())

  @@index([ip, createdAt])
}

// -----------------------------------------------------------------------------
// OpenTicket Core Models
// -----------------------------------------------------------------------------

enum AssetType {
  SERVER
  ENDPOINT
  NETWORK
  SOFTWARE
  OTHER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  COMPROMISED
  MAINTENANCE
}

model Asset {
  id        String      @id @default(cuid())
  name      String
  type      AssetType   @default(OTHER)
  ipAddress String?
  status    AssetStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  incidents       Incident[]
  vulnerabilities Vulnerability[] @relation("AssetVulnerabilities")
}

enum VulnStatus {
  OPEN
  MITIGATED
  RESOLVED
}

model Vulnerability {
  id            String     @id @default(cuid())
  title         String
  cveId         String?
  cvssScore     Float?
  description   String     @db.Text
  severity      Severity   @default(LOW)
  status        VulnStatus @default(OPEN)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  targetSlaDate DateTime?

  affectedAssets Asset[]      @relation("AssetVulnerabilities")
  attachments    Attachment[]
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  NEW
  IN_PROGRESS
  PENDING_INFO
  RESOLVED
  CLOSED
}

enum IncidentType {
  MALWARE
  PHISHING
  DATA_BREACH
  UNAUTHORIZED_ACCESS
  NETWORK_ANOMALY
  OTHER
}

model Incident {
  id          String         @id @default(cuid())
  title       String
  description String         @db.Text
  type        IncidentType   @default(OTHER)
  severity    Severity       @default(LOW)
  status      IncidentStatus @default(NEW)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  reporterId String?
  reporter   User?   @relation("Reporter", fields: [reporterId], references: [id], onDelete: SetNull)

  tags        String[]       @default([])

  assignees User[] @relation("IncidentAssignees")

  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  targetSlaDate DateTime?

  comments    Comment[]
  attachments Attachment[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String // e.g., "INCIDENT_CREATED", "STATUS_CHANGED"
  entityType String // e.g., "Incident", "Asset"
  entityId   String
  changes    Json? // Optional JSON payload detailing what changed
  createdAt  DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  fileUrl   String
  createdAt DateTime @default(now())

  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  vulnId String?
  vuln   Vulnerability? @relation(fields: [vulnId], references: [id], onDelete: Cascade)

  uploaderId String?
  uploader   User?   @relation(fields: [uploaderId], references: [id], onDelete: SetNull)
}
// -----------------------------------------------------------------------------
// Machine-to-Machine Authenticators
// -----------------------------------------------------------------------------

model ApiToken {
  id          String    @id @default(cuid())
  name        String
  tokenHash   String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  lastUsedAt  DateTime?

  @@index([tokenHash])
}

// -----------------------------------------------------------------------------
// Plugin Management
// -----------------------------------------------------------------------------

model PluginState {
  id          String   @id // Corresponds to OpenTicketPlugin.manifest.id
  isActive    Boolean  @default(false)
  configJson  String?  @db.Text
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Time-Series Data Snapshots (Dashboard Cache)
// -----------------------------------------------------------------------------

model MetricSnapshot {
  id          String   @id @default(cuid())
  timestamp   DateTime // Defines the 30-min window
  scopeType   String   // 'GLOBAL' or 'USER'
  scopeId     String   // 'ALL' or user_id
  
  payload     String   @db.Text // JSON with detailed active counts and rates
  
  createdAt   DateTime @default(now())

  @@unique([timestamp, scopeType, scopeId])
  @@index([timestamp])
}
