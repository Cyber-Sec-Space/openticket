# ================================================
# OpenTicket Production Environment Variables
# ================================================

# [ 1. NEXTAUTH CORE SETTINGS ]
# The secret used to encrypt session data. Must be strong!
# Generate one using: openssl rand -base64 33
AUTH_SECRET=generate_a_super_strong_secret_for_production
NEXTAUTH_SECRET=generate_a_super_strong_secret_for_production_2

# Trust Proxy Headers (Set to true if using Docker/Reverse Proxy to get real Client IPs)
TRUST_PROXY_HEADERS=true

# The public canonical URL of your deployment (e.g., https://openticket.myapp.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [ 2. DATABASE CONFIGURATION ]
POSTGRES_USER=openticket_admin
POSTGRES_PASSWORD=replace_with_a_secure_database_password
POSTGRES_DB=openticket_prod

# PRISMA DATABASE URL - For local development against Docker, use pg-bouncer port 5432 or 6432
# Note: Docker-compose overrides this for intra-container networking.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public

# [ 3. MAIL / SMTP NOTIFICATIONS (Optional) ]
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=OpenTicket <noreply@openticket.io>
